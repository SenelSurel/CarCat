<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="CarCat.Views.HomePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Home"
    BackgroundColor="White"
    Shell.NavBarIsVisible="False">

    <Grid
        Padding="16"
        RowDefinitions="Auto,*"
        RowSpacing="16"
        VerticalOptions="Center">
        <VerticalStackLayout Spacing="8">
            <Image HorizontalOptions="Center" Source="splash.svg" />
            <Label Style="{StaticResource TitleText}" Text="Car Category" />
            <Label Style="{StaticResource BodyText}" Text="Browse vehicles based on make, model, road, engine, and transmission information." />
        </VerticalStackLayout>

        <VerticalStackLayout Grid.Row="1" Spacing="12">
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />
            <Button
                Clicked="OnCarsClicked"
                FontSize="16"
                Style="{StaticResource PrimaryButton}"
                Text="{Binding CarsCountText}" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>