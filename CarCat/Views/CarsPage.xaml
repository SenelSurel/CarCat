<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="CarCat.Views.CarsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    Title="Cars">

    <Grid
        Padding="16"
        RowDefinitions="Auto,Auto,*"
        RowSpacing="12">

        <!--  ROW 0: FILTER PANEL + RESULTS COUNT  -->
        <VerticalStackLayout Grid.Row="0" Spacing="10">

            <toolkit:Expander>
                <toolkit:Expander.Header>
                    <Border
                        Padding="12"
                        StrokeShape="RoundRectangle 14"
                        StrokeThickness="0">
                        <HorizontalStackLayout Spacing="10">
                            <Border
                                Padding="8.5"
                                BackgroundColor="{StaticResource Primary}"
                                StrokeShape="RoundRectangle 5">
                                <Label
                                    FontAttributes="Bold"
                                    Text="Filters"
                                    TextColor="White" />
                            </Border>

                            <Label
                                Margin="10"
                                FontSize="14"
                                HorizontalOptions="Center"
                                Opacity="0.6"
                                Text="Tap to expand/collapse" />
                        </HorizontalStackLayout>
                    </Border>
                </toolkit:Expander.Header>

                <toolkit:Expander.Content>
                    <VerticalStackLayout Margin="0,10,0,0" Spacing="10">

                        <!--  Brand + Transmission  -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <VerticalStackLayout>
                                <Label
                                    FontSize="14"
                                    Opacity="0.7"
                                    Text="Brand" />
                                <Picker ItemsSource="{Binding Brands}" SelectedItem="{Binding SelectedBrand}" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="1">
                                <Label
                                    FontSize="14"
                                    Opacity="0.7"
                                    Text="Transmission" />
                                <Picker ItemsSource="{Binding TransmissionOptions}" SelectedItem="{Binding SelectedTransmission}" />
                            </VerticalStackLayout>
                        </Grid>

                        <!--  Year + Engine ranges  -->
                        <Grid
                            ColumnDefinitions="*,*"
                            ColumnSpacing="12"
                            RowDefinitions="Auto,Auto"
                            RowSpacing="10">

                            <VerticalStackLayout>
                                <Label
                                    FontSize="14"
                                    Opacity="0.7"
                                    Text="Year From" />
                                <Entry
                                    Keyboard="Numeric"
                                    Placeholder="2016"
                                    Text="{Binding YearFromText}" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="1">
                                <Label
                                    FontSize="14"
                                    Opacity="0.7"
                                    Text="Year To" />
                                <Entry
                                    Keyboard="Numeric"
                                    Placeholder="2022"
                                    Text="{Binding YearToText}" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Row="1">
                                <Label
                                    FontSize="14"
                                    Opacity="0.7"
                                    Text="Engine From (cc)" />
                                <Entry
                                    Keyboard="Numeric"
                                    Placeholder="1400"
                                    Text="{Binding EngineFromText}" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Row="1" Grid.Column="1">
                                <Label
                                    FontSize="14"
                                    Opacity="0.7"
                                    Text="Engine To (cc)" />
                                <Entry
                                    Keyboard="Numeric"
                                    Placeholder="2000"
                                    Text="{Binding EngineToText}" />
                            </VerticalStackLayout>
                        </Grid>

                        <Button
                            Command="{Binding ClearFiltersCommand}"
                            HeightRequest="44"
                            Text="Clear Filters"
                            TextColor="White" />

                    </VerticalStackLayout>
                </toolkit:Expander.Content>
            </toolkit:Expander>

            <!--  Search Bar  -->
            <SearchBar Placeholder="Search brand or model..." Text="{Binding SearchText}" />

            <!--  Results count  -->
            <Label
                FontSize="14"
                Opacity="0.7"
                Text="{Binding ResultsCount, StringFormat='Results: {0}'}" />
        </VerticalStackLayout>

        <!--  ROW 1: LOADING  -->
        <HorizontalStackLayout
            Grid.Row="1"
            IsVisible="{Binding IsBusy}"
            Spacing="10">
            <ActivityIndicator IsRunning="{Binding IsBusy}" />
            <Label Text="Loading..." VerticalTextAlignment="Center" />
        </HorizontalStackLayout>

        <!--  ROW 2: LIST AREA (EMPTY STATE + LIST)  -->
        <Grid Grid.Row="2">

            <!--  Empty State (converter yok, code-behind kontrol edecek)  -->
            <VerticalStackLayout
                x:Name="EmptyState"
                HorizontalOptions="Center"
                IsVisible="False"
                Spacing="6"
                VerticalOptions="Center">
                <Label
                    FontAttributes="Bold"
                    FontSize="18"
                    Text="No results" />
                <Label
                    FontSize="13"
                    Opacity="0.7"
                    Text="Try clearing filters or adjusting ranges." />
            </VerticalStackLayout>

            <!--  List  -->
            <CollectionView
                ItemsSource="{Binding Cars}"
                SelectionChanged="OnSelectionChanged"
                SelectionMode="Single">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout ItemSpacing="12" Orientation="Vertical" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Padding="0"
                            Stroke="{SolidColorBrush Grey}"
                            StrokeShape="RoundRectangle 18"
                            StrokeThickness="1">

                            <Grid RowDefinitions="160,Auto">
                                <!--  Banner Image  -->
                                <Grid>
                                    <Image
                                        Aspect="AspectFill"
                                        HeightRequest="160"
                                        Source="{Binding Image}" />

                                    <!--  readable overlay  -->
                                    <BoxView Color="#77000000" />
                                    <VerticalStackLayout
                                        Padding="12"
                                        Spacing="2"
                                        VerticalOptions="End">
                                        <Label
                                            FontAttributes="Bold"
                                            FontSize="20"
                                            Text="{Binding Brand}"
                                            TextColor="White" />
                                        <Label
                                            FontSize="16"
                                            Opacity="0.9"
                                            Text="{Binding Model}"
                                            TextColor="White" />
                                    </VerticalStackLayout>
                                </Grid>

                                <!--  Details  -->
                                <Grid
                                    Grid.Row="1"
                                    Padding="12"
                                    ColumnDefinitions="*,*,*"
                                    ColumnSpacing="10"
                                    RowDefinitions="Auto,Auto"
                                    RowSpacing="6">

                                    <Label
                                        FontSize="15"
                                        Opacity="0.75"
                                        Text="{Binding Year, StringFormat='Year: {0}'}" />

                                    <Label
                                        Grid.Column="1"
                                        FontSize="15"
                                        Opacity="0.75"
                                        Text="{Binding HorsePower, StringFormat='Power: {0} hp'}" />

                                    <Label
                                        Grid.Column="2"
                                        FontSize="15"
                                        Opacity="0.75"
                                        Text="{Binding EngineDisplacementCc, StringFormat='Engine: {0} cc'}" />

                                    <Label
                                        Grid.Row="1"
                                        Grid.ColumnSpan="2"
                                        FontSize="15"
                                        Opacity="0.75"
                                        Text="{Binding Transmission, StringFormat='Transmission: {0}'}" />
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
    </Grid>
</ContentPage>